{
  "name": "creonow",
  "version": "0.0.1",
  "private": true,
  "description": "AI 驱动的文字创作 IDE",
  "type": "module",
  "scripts": {
    "desktop:dev": "pnpm -C apps/desktop dev",
    "desktop:rebuild:native": "pnpm -C apps/desktop rebuild:native",
    "desktop:build": "pnpm -C apps/desktop build",
    "desktop:test:e2e": "pnpm -C apps/desktop test:e2e",
    "desktop:build:win": "pnpm -C apps/desktop build:win",
    "contract:generate": "tsx scripts/contract-generate.ts",
    "contract:check": "pnpm contract:generate && git diff --exit-code packages/shared/types/ipc-generated.ts",
    "cross-module:check": "tsx scripts/cross-module-contract-gate.ts",
    "cross-module:autofix": "tsx scripts/cross-module-contract-autofix.ts",
    "test:ipc:acceptance": "tsx apps/desktop/tests/perf/ipc-request-response.acceptance.spec.ts && tsx apps/desktop/tests/perf/ipc-push.acceptance.spec.ts && tsx apps/desktop/tests/perf/ipc-validation.acceptance.spec.ts && tsx apps/desktop/tests/perf/ipc-acceptance-gate.spec.ts && tsx scripts/ipc-acceptance-gate.ts",
    "test:unit": "pnpm desktop:ensure-native-node-abi && tsx scripts/run-discovered-tests.ts --mode unit",
    "test:integration": "tsx scripts/run-discovered-tests.ts --mode integration",
    "test:discovery:consistency": "tsx scripts/test-discovery-consistency-gate.ts",
    "test:coverage:desktop": "pnpm -C apps/desktop test:coverage",
    "test:coverage:core": "pnpm -C apps/desktop test:coverage:core",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:warning-budget": "tsx scripts/lint-ratchet.ts",
    "lint:warning-budget:update": "tsx scripts/lint-ratchet.ts --write-baseline",
    "lint:ratchet": "pnpm lint:warning-budget",
    "lint:ratchet:update": "pnpm lint:warning-budget:update",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "desktop:ensure-native-node-abi": "tsx scripts/ensure-desktop-native-node-abi.ts",
    "test:unit:after-desktop-rebuild": "pnpm -C apps/desktop rebuild:native && pnpm test:unit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "@electron/rebuild": "4.0.3",
      "@isaacs/brace-expansion@<=5.0.0": "5.0.1",
      "ajv@<6.14.0": "6.14.0",
      "markdown-it@>=13.0.0 <14.1.1": "14.1.1",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=10.0.0 <10.2.3": "10.2.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "storybook@>=8.1.0 <8.6.17": "8.6.17",
      "tar@<7.5.8": "7.5.9"
    }
  }
}
