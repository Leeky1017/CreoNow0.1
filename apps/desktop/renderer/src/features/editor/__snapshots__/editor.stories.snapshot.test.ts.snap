exports[`editor stories snapshots > [ED-TEST-01] should cover toolbar + write button story states > editor-toolbar-no-editor 1`] = `
<div
  class="w-full max-w-[800px]"
>
  <div
    class="border border-[var(--color-border-default)] rounded-[var(--radius-md)]"
  >
    <div
      class="p-4 min-h-[100px] text-[var(--color-fg-muted)]"
    >
      Toolbar returns null when no editor is provided.
    </div>
  </div>
</div>
`;

