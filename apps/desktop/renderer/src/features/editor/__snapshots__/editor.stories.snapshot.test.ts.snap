<div
  class="relative h-[240px] w-[480px] rounded-[var(--radius-md)] border border-[var(--color-border-default)] bg-[var(--color-bg-base)] p-4"
>
  <div
    class="text-sm text-[var(--color-fg-muted)]"
  >
    Hover editor region to show floating actions.
  </div>
  <div
    class="pointer-events-none absolute bottom-3 right-3 z-[var(--z-dropdown)]"
    data-testid="write-button-group"
  >
    <button
      class="
            pointer-events-auto inline-flex min-w-[88px] items-center justify-center rounded-[var(--radius-md)] border px-3 py-1.5 text-xs font-semibold transition-colors
            cursor-not-allowed border-[var(--color-border-default)] bg-[var(--color-bg-raised)] text-[var(--color-fg-muted)] opacity-70
          "
      data-state="closed"
      data-testid="write-button-trigger"
      disabled=""
      type="button"
    >
      Continue Writing
    </button>
  </div>
</div>
`;

