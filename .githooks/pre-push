#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-origin}"
remote_url="${2:-}"

if [[ "${CREONOW_ALLOW_CONTROLPLANE_BYPASS:-}" == "1" ]]; then
  exit 0
fi

TOPLEVEL="$(git rev-parse --show-toplevel)"
COMMON_DIR="$(git rev-parse --git-common-dir)"
CONTROLPLANE_ROOT="$(cd "$(dirname "$COMMON_DIR")" && pwd -P)"
CURRENT_BRANCH="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo HEAD)"

if [[ "$(cd "$TOPLEVEL" && pwd -P)" == "$CONTROLPLANE_ROOT" ]]; then
  echo "ERROR: direct pushes from controlplane root are blocked." >&2
  echo "Current branch: $CURRENT_BRANCH" >&2
  echo "Use scripts/agent_task_begin.sh <issue-number> <slug> to create a task worktree first." >&2
  echo "Override only for emergency hotfixes with CREONOW_ALLOW_CONTROLPLANE_BYPASS=1." >&2
  exit 1
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/main" || "$local_ref" == "refs/heads/main" ]]; then
    echo "ERROR: direct pushes to main are blocked. Use Issue -> task branch -> PR -> checks -> merge." >&2
    echo "remote=$remote_name url=$remote_url ref=$remote_ref" >&2
    echo "Override only for emergency hotfixes with CREONOW_ALLOW_CONTROLPLANE_BYPASS=1." >&2
    exit 1
  fi
done
